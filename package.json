{
  "name": "prettier-now",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.8.0",
  "description": "Yet another Prettier browser extension for code formatting.",
  "keywords": [
    "browser-extension",
    "prettier"
  ],
  "license": "MIT",
  "author": {
    "name": "ntnyq",
    "email": "ntnyq13@gmail.com"
  },
  "homepage": "https://github.com/ntnyq/prettier-now",
  "repository": "ntnyq/prettier-now",
  "bugs": {
    "url": "https://github.com/ntnyq/prettier-now/issues"
  },
  "scripts": {
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "lint": "eslint",
    "postinstall": "wxt prepare",
    "prepare": "husky",
    "release": "bumpp",
    "test": "vitest",
    "typecheck": "vue-tsc --build",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox"
  },
  "dependencies": {
    "@codemirror/lang-angular": "^0.1.4",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-less": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-sass": "^6.0.2",
    "@codemirror/lang-vue": "^0.1.3",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@lezer/highlight": "^1.2.3",
    "@lucide/vue": "^1.21.0",
    "@ntnyq/utils": "^0.15.0",
    "@prettier/plugin-php": "^0.25.0",
    "@prettier/plugin-pug": "^3.4.2",
    "@prettier/plugin-xml": "^3.4.2",
    "@replit/codemirror-lang-svelte": "^6.0.0",
    "@uiw/codemirror-themes": "^4.25.10",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cm6-graphql": "^0.2.1",
    "codemirror": "^6.0.2",
    "dayjs": "^1.11.21",
    "pinia": "^3.0.4",
    "prettier": "^3.8.4",
    "prettier-plugin-java": "^2.9.7",
    "prettier-plugin-svelte": "^4.1.1",
    "prettier-plugin-toml": "2.0.2",
    "reka-ui": "^2.10.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.5.38",
    "vue-codemirror": "^6.1.1",
    "vue-router": "^5.1.0",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@ntnyq/eslint-config": "^6.1.5",
    "@ntnyq/prettier-config": "^3.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@wxt-dev/auto-icons": "^1.1.1",
    "@wxt-dev/i18n": "^0.2.5",
    "@wxt-dev/module-vue": "^1.0.3",
    "bumpp": "^11.1.0",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "nano-staged": "^1.0.2",
    "npm-run-all2": "^9.0.2",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5",
    "wxt": "^0.20.26"
  },
  "nano-staged": {
    "*.{js,ts,cjs,mjs,md,vue,svg,yml,yaml,toml,json}": "eslint --fix",
    "*.{css,scss,html}": "prettier -uw"
  }
}
